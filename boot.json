  "addonPlugin": [
    {
      "modName": "TweeReplacer",
      "addonName": "TweeReplacerAddon",
      "modVersion": "1.0.0",
      "params": [
        {
          "passage": "Widgets",
          "findString": "\t\t\t<<set $pain += (_violence * _painMod * (1 - ($masochism / 1200)) * (1 - ($sciencetrait / 10)) / _possessMod / _clothesMod)>>",
          "replaceFile": "addon-replace/Widgets_3.txt",
          "comments": "金鐘罩、鐵布衫"
        },
        {
          "passage": "Widgets",
          "findString": "\t\t\t<<set $pain += (_violence * _painMod * (1 - ($masochism / 1200)) * (1 - ($sciencetrait / 10)))>>",
          "replaceFile": "addon-replace/Widgets_4.txt",
          "comments": "金鐘罩、鐵布衫"
        },
        {
          "passage": "Widgets",
          "findString": "\t\t<<set _thedamage to (2 * _defiance * ($physique / 4000))>>",
          "replaceFile": "addon-replace/Widgets_5.txt",
          "comments": "小鎮拳皇"
        },
        {
          "passage": "Widgets",
          "findString": "\t\t<<set $enemyhealth -= _thedamage>>",
          "replaceFile": "addon-replace/Widgets_6.txt",
          "comments": "小鎮拳皇"
        },
        {
          "passage": "Widgets Bodywriting",
          "findString": "\"<span class=\"purple\"><<print $skin[_active_bodypart].writ_cn>></span>\"",
          "replace": "<<CE_tattoo_color>>",
          "comments": "魔術迴路紋身顏色添加"
        },
        {
          "passage": "Widgets Market",
          "findString": "<<widget \"stall_sell_actions\">>",
          "replaceFile": "addon-replace/Widgets Market_1.txt",
          "comments": "黑心商店"
        },
        {
          "passage": "Widgets Market",
          "findString": "\t<<if $stall_amount gte $plants[$stall_plant].amount>>",
          "replaceFile": "addon-replace/Widgets Market_2.txt",
          "all": true,
          "comments": "黑心商店"
        },
        {
          "passage": "Widgets Orgasm",
          "findString": "<<if $milk_amount lt _milk_released>>",
          "replace": "<<milk_releasedFIX _milk_released>>\n\t<<set _milk_released += $milk_releasedFIX>>\n\t<<if $milk_amount lt _milk_released>>",
          "comments": "大量產奶"
        },
        {
          "passage": "Widgets Dance Audience",
          "findString": "\t\t\t\t<<set $dancetip *= 1 + ($mathstrait / 4)>>",
          "replaceFile": "addon-replace/Widgets Dance Audience.txt",
          "comments": "跳舞報酬加倍"
        },
        {
          "passage": "StoryCaption",
          "findString": "<<if $options.sidebarStats isnot \"disabled\">>",
          "replaceFile": "addon-replace/StoryCaption.txt",
          "comments": "作弊拓展入口"
        },
        {
          "passage": "Pregnancy",
          "findString": "<<case 0 1 2 3>>",
          "replace": "<<case _args[0] is a number>>",
          "all": true,
          "comments": "寄生物插槽擴充分娩相關代碼patch"
        },
        {
          "passage": "Pregnancy",
          "findString": "_args[0] lte 3",
          "replace": "$_pregnancy.fetus[_args[0]] isnot undefined",         
          "comments": "寄生物插槽擴充分娩相關代碼patch"
        },
        {
          "passage": "Widgets Text",
          "findString": "<<switch Skin.color.natural>>",
          "replace": "<<skinColourFallback>><<switch Skin.color.natural>>",         
          "comments": "針對自定義膚色輸出對應文字patch"
        }
      ]
    },
    {
      "modName": "ReplacePatcher",
      "addonName": "ReplacePatcherAddon",
      "modVersion": "1.0.0",
      "params": {
        "js": [
          {
            "TODO": "semen_releasedFIX",
            "from": "\tif (V.cow >= 6) released *= 2;",
            "to": "\tif (V.cow >= 6) released *= 2;\n\tif (V.semen_releasedFIX > 1) released *= V.semen_releasedFIX;\n",
            "fileName": "ingame.js"
          },
          {
            "TODO": "function=>hook money",
            "from": "DefineMacro(\"money\", money);",
            "to": "window.money = money;\n\tconsole.log(\"[Cheat Extended] 🔧 money 函數已掛到全局\");\n\tDefineMacro(\"money\", money);",
            "fileName": "stat-changes.js"
          },
          {
            "TODO": "function=>patch earnHourlyFeats",
            "from": "if (V.feats.locked || V.cheatsEnabled === true || V.debug || V.gamemode === \"soft\" || V.settings.allureModifier < 1 || V.replayScene) return false;",
            "to": "if (V.gamemode === \"soft\" || V.replayScene) return false;",
            "fileName": "feats.js"
          },
          {
            "TODO": "patch => maxParasites",
            "from": "switch (V.sexStats[genital].pregnancy.motherStatus)",
            "to": "if (V.CE_parasiteControl){\n\t\t return CE_parasiteControlLimit(genital)\n\t};\n\tswitch (V.sexStats[genital].pregnancy.motherStatus)",
            "fileName": "pregnancy-types.js"
          }                          
        ],
        "twee": [
          {
            "TODO": "作弊模式解鎖成就系統",
            "passageName": "FeatsUI",
            "from": "<<if $feats.locked>>",
            "to": "<<if $feats.locked and !$CE_featBypass>>"
          },
          {
            "TODO": "調試模式解鎖成就系統",
            "passageName": "FeatsUI",
            "from": "<<elseif $debug is 1>>",
            "to": "<<elseif $debug is 1 and !$CE_featBypass>>"
          }
        ]
      }
    }
  ],
